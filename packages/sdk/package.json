{
  "name": "@catalyst/sdk",
  "version": "0.0.1",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run unit.test.ts --passWithNoTests",
    "test:integration": "vitest run integration.test.ts --passWithNoTests --no-file-parallelism --maxWorkers=1 --testTimeout=30000 --hookTimeout=30000",
    "test:container": "vitest run container.test.ts --passWithNoTests --no-file-parallelism --maxWorkers=1 --testTimeout=300000 --hookTimeout=300000",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@types/node": "catalog:dev",
    "@vitest/coverage-v8": "catalog:testing",
    "tsup": "catalog:dev",
    "typescript": "catalog:dev",
    "vitest": "catalog:testing"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "catalog:",
    "graphql": "catalog:",
    "graphql-yoga": "catalog:"
  }
}
