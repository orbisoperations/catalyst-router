{
  "name": "@catalyst/service",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "test": "vitest run",
    "test:unit": "vitest run unit.test.ts --passWithNoTests",
    "test:integration": "vitest run integration.test.ts --passWithNoTests --no-file-parallelism --maxWorkers=1 --testTimeout=30000 --hookTimeout=30000",
    "typecheck": "tsc --noEmit",
    "test:container": "vitest run container.test.ts --passWithNoTests --no-file-parallelism --maxWorkers=1 --testTimeout=300000 --hookTimeout=300000"
  },
  "dependencies": {
    "@catalyst/config": "workspace:*",
    "@catalyst/telemetry": "workspace:*",
    "@hono/node-server": "catalog:",
    "@hono/node-ws": "catalog:",
    "hono": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:dev",
    "typescript": "catalog:dev",
    "vitest": "catalog:testing"
  }
}
